        {
          "name": "Job Seeker Auth",
          "description": "Register, verify OTP, and login for job seekers.",
          "item": [
            {
              "name": "Register Job Seeker",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"full_name\": \"Test Seeker\",\n  \"email\": \"seeker@example.com\",\n  \"phone_number\": \"+963912345678\",\n  \"password\": \"securepass123\",\n  \"password_confirm\": \"securepass123\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/auth/job-seeker/register/"
                }
              }
            },
            {
              "name": "Verify Job Seeker OTP",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"seeker@example.com\",\n  \"otp\": \"123456\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/auth/job-seeker/verify-otp/"
                }
              }
            },
            {
              "name": "Job Seeker Login",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"seeker@example.com\",\n  \"password\": \"securepass123\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/auth/job-seeker/login/"
                }
              }
            }
          ]
        },
