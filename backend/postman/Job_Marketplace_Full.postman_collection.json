{
  "info": {
    "name": "Job Marketplace Backend API (Full)",
    "description": "Complete Postman collection for the Django job marketplace backend. Import this file and use the companion environment file to test the API locally.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "company_token", "value": "", "type": "string" },
    { "key": "jobseeker_token", "value": "", "type": "string" },
    { "key": "auth_token", "value": "", "type": "string" },
    { "key": "job_id", "value": "1", "type": "string" },
    { "key": "application_id", "value": "1", "type": "string" },
    { "key": "specialization_id", "value": "1", "type": "string" },
    { "key": "skill_id", "value": "1", "type": "string" },
    { "key": "experience_id", "value": "1", "type": "string" },
    { "key": "education_id", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "01 - Utility",
      "item": [
        {
          "name": "API Home",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/"
          }
        },
        {
          "name": "Get Choices",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/choices/"
          }
        },
        {
          "name": "Job Seekers Count",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/jobseekers/count/"
          }
        }
      ]
    },
    {
      "name": "02 - Authentication",
      "item": [
        {
          "name": "Register Job Seeker",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Test Seeker\",\n  \"email\": \"seeker@example.com\",\n  \"phone_number\": \"+963912345678\",\n  \"password\": \"securepass123\",\n  \"password_confirm\": \"securepass123\"\n}"
            },
            "url": "{{base_url}}/api/auth/job-seeker/register/"
          }
        },
        {
          "name": "Verify Job Seeker OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seeker@example.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{base_url}}/api/auth/job-seeker/verify-otp/"
          }
        },
        {
          "name": "Login Job Seeker",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = JSON.parse(responseBody);",
                  "if (data && data.token) {",
                  "  pm.collectionVariables.set('jobseeker_token', data.token);",
                  "  pm.environment.set('jobseeker_token', data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seeker@example.com\",\n  \"password\": \"securepass123\"\n}"
            },
            "url": "{{base_url}}/api/auth/login/"
          }
        },
        {
          "name": "Register Company",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company_name\": \"Example Co\",\n  \"email\": \"company@example.com\",\n  \"phone_number\": \"+963912345679\",\n  \"governorate\": \"damascus\",\n  \"company_type\": \"programming\",\n  \"website_url\": \"https://example.com\",\n  \"description\": \"Sample company description\",\n  \"password\": \"securepass123\",\n  \"password_confirm\": \"securepass123\"\n}"
            },
            "url": "{{base_url}}/api/auth/company/register/"
          }
        },
        {
          "name": "Verify Company OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"company@example.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{base_url}}/api/auth/company/verify-otp/"
          }
        },
        {
          "name": "Login Company",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = JSON.parse(responseBody);",
                  "if (data && data.token) {",
                  "  pm.collectionVariables.set('company_token', data.token);",
                  "  pm.environment.set('company_token', data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"company@example.com\",\n  \"password\": \"securepass123\"\n}"
            },
            "url": "{{base_url}}/api/auth/login/"
          }
        },
        {
          "name": "Google Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_token\": \"your-google-id-token\"\n}"
            },
            "url": "{{base_url}}/api/auth/google/login/"
          }
        },
        {
          "name": "Password Reset Request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seeker@example.com\"\n}"
            },
            "url": "{{base_url}}/api/auth/password/reset/"
          }
        },
        {
          "name": "Password Reset Validate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"uidb64\": \"MQ\",\n  \"token\": \"your-reset-token\"\n}"
            },
            "url": "{{base_url}}/api/auth/password/reset/validate/"
          }
        },
        {
          "name": "Password Reset Confirm",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"uidb64\": \"MQ\",\n  \"token\": \"your-reset-token\",\n  \"new_password\": \"newsecurepass123\"\n}"
            },
            "url": "{{base_url}}/api/auth/password/reset/confirm/"
          }
        }
      ]
    },
    {
      "name": "03 - Company Profile",
      "item": [
        {
          "name": "Get Company Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "CompanyToken {{company_token}}"
              }
            ],
            "url": "{{base_url}}/api/company/profile/"
          }
        },
        {
          "name": "Upload Company Profile Picture",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "CompanyToken {{company_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "profile_picture", "type": "file", "src": [] }
              ]
            },
            "url": "{{base_url}}/api/company/profile/picture/"
          }
        }
      ]
    },
